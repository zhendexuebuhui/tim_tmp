# Runtime state generated by the in-container model manager is ignored by
# default. Keep diagnostic artifacts visible to Git so they can be reviewed
# after a benchmark or serving run.
/runtime/*
!/runtime/qwen3.6-27b/
/runtime/qwen3.6-27b/*
!/runtime/qwen3.6-27b/serve-*.log
!/runtime/qwen3.6-27b/bench-*.log
!/runtime/qwen3.6-27b/bench-*.json
!/runtime/qwen3.6-27b/bench-*-npu.csv
!/runtime/qwen3.6-27b/bench-*-summary.txt
